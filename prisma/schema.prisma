generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------
// ENUMS (Listas de valores fijos)
// ------------------------------------------

enum PlanType {
  FREE
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  EXPIRED
  CANCELLED
}

enum AppointmentStatus {
  PENDING     // Reservada
  CONFIRMED   // Aceptada por barbero (opcional)
  COMPLETED   // Servicio realizado
  CANCELLED   // Por cliente o barbero
  NO_SHOW     // Cliente no llegó
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD        // Preparado para futuro (Stripe, etc)
}

enum TransactionType {
  SERVICE     // Cobro de cita
  PRODUCT     // Venta de producto (cera, gel)
  TIP         // Propina
  OTHER       // Ajustes
  WITHDRAWAL  // (Retiro/Gasto)
}

// NUEVO: Roles Jerárquicos
enum Role {
  OWNER    // Dueño: Configura suscripción, ve toda la sucursal
  ADMIN    // Gerente: Ve reportes globales, no toca pagos
  BARBER   // Empleado: Solo ve sus citas y sus métricas
}

// ------------------------------------------
// MODELOS (Tablas)
// ------------------------------------------

/// 🏢 NUEVA ENTIDAD: La Sucursal / Barbería (El Tenant)
model Barbershop {
  id            String   @id @default(uuid())
  name          String   @map("nombre_comercial")
  slug          String   @unique @map("alias_url")
  
  // Tiempo y Ubicación de la Sucursal
  timeZone      String   @default("America/Merida") @map("zona_horaria")
  address       String?  @map("direccion_texto")
  latitude      Float?   @map("latitud")
  longitude     Float?   @map("longitud")
  
  isActive      Boolean  @default(true) @map("activa")
  createdAt     DateTime @default(now()) @map("fecha_creacion")

  // Relaciones (La sucursal es dueña de esto)
  subscription  Subscription?
  staff         Barber[]         
  services      Service[]        
  clients       Client[]         
  appointments  Appointment[]
  transactions  Transaction[]
  dailyOpens    DailyOpen[]
  dailyCloses   DailyClose[]
  gallery       GalleryImage[]

  @@map("barberias")
}

/// 👤 STAFF: Barbero (Ahora es parte de una sucursal)
model Barber {
  id            String    @id @default(uuid())
  barbershopId  String    @map("barberia_id") // Vínculo a la sucursal
  
  fullName      String    @map("nombre_completo")
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  googleId      String?   @unique @map("google_id")
  phone         String?   @map("telefono")
  avatarUrl     String?   @map("foto_perfil")
  
  role          Role      @default(BARBER) // Define qué puede ver y hacer
  rankingScore  Decimal   @default(0.00) @db.Decimal(3, 2) @map("ranking_score")
  isActive      Boolean   @default(true) @map("estado_cuenta")

  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")

  createdAt     DateTime  @default(now()) @map("fecha_registro")
  updatedAt     DateTime  @updatedAt

  // Relaciones
  barbershop    Barbershop       @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  schedules     ScheduleConfig[]
  blocks        ScheduleBlock[]
  appointments  Appointment[]
  transactions  Transaction[]
  dailyOpens    DailyOpen[]
  dailyCloses   DailyClose[]
  reviews       Review[]
  notifications Notification[]

  @@map("personal")
}

/// 🧑‍🤝‍🧑 CLIENTE FINAL (Pertenece a la Sucursal)
model Client {
  id            String    @id @default(uuid())
  barbershopId  String    @map("barberia_id") // Modificado

  name          String    @map("nombre")
  phone         String    @map("telefono")
  email         String?   @map("email")
  phoneHash     String?   @map("telefono_hash")
  internalNotes String?   @map("notas_internas")

  createdAt     DateTime  @default(now()) @map("fecha_creacion")

  barbershop    Barbershop  @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments  Appointment[]

  @@unique([phone, barbershopId], name: "client_phone_per_shop")
  @@index([phoneHash])
  @@map("clientes")
}

/// 💳 SUSCRIPCIÓN (La paga la Sucursal)
model Subscription {
  id               Int       @id @default(autoincrement())
  barbershopId     String    @unique @map("barberia_id") // Modificado
  
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  type             PlanType  @map("tipo_plan")
  startDate        DateTime  @map("fecha_inicio")
  endDate          DateTime  @map("fecha_vencimiento")
  status           SubscriptionStatus @default(PENDING) @map("estado_pago")

  barbershop       Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@map("suscripciones")
}

/// ✂️ SERVICIOS (Catálogo de la Sucursal)
model Service {
  id            Int       @id @default(autoincrement())
  barbershopId  String    @map("barberia_id") // Modificado
  name          String    @map("nombre")
  price         Decimal   @db.Decimal(10, 2) @map("precio")
  durationMin   Int       @map("duracion_min")
  isActive      Boolean   @default(true) @map("activo")

  barbershop    Barbershop     @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  galleryImages GalleryImage[]

  @@map("servicios")
}

/// 📅 HORARIOS (Asignados a cada Barbero individualmente)
model ScheduleConfig {
  id          Int       @id @default(autoincrement())
  barberId    String    @map("personal_id")
  dayOfWeek   Int       @map("dia_semana") 
  startTime   DateTime  @db.Time @map("hora_apertura")
  endTime     DateTime  @db.Time @map("hora_cierre")
  breakStart  DateTime? @db.Time @map("descanso_inicio")
  breakEnd    DateTime? @db.Time @map("descanso_fin")
  isWorkDay   Boolean   @default(true) @map("es_laborable")

  barber      Barber    @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
  @@map("configuracion_horarios")
}

model ScheduleBlock {
  id          Int       @id @default(autoincrement())
  barberId    String    @map("personal_id")
  startDate   DateTime  @map("fecha_inicio")
  endDate     DateTime  @map("fecha_fin")
  reason      String?   @map("motivo")

  barber      Barber    @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("bloqueos_agenda")
}

/// 🗓️ CITAS (Asignadas a la Sucursal y a un Barbero)
model Appointment {
  id            String    @id @default(uuid())
  barbershopId  String    @map("barberia_id") // La cita es de la tienda
  barberId      String    @map("personal_id") // Atendida por este barbero
  clientId      String    @map("cliente_id")
  serviceId     Int       @map("servicio_id")
  
  date          DateTime  @map("fecha_hora")
  frozenPrice   Decimal   @db.Decimal(10, 2) @map("precio_congelado")
  status        AppointmentStatus @default(PENDING) @map("estado")
  origin        String    @default("APP")
  notes         String?   @map("notas")
  reminderSent  Boolean   @default(false) @map("recordatorio_enviado")

  createdAt     DateTime  @default(now())

  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])
  barber        Barber     @relation(fields: [barberId], references: [id])
  client        Client     @relation(fields: [clientId], references: [id])
  service       Service    @relation(fields: [serviceId], references: [id])
  
  transaction   Transaction[]
  review        Review?

  @@index([barbershopId, date])
  @@map("citas")
}

/// 💰 MOVIMIENTOS FINANCIEROS (POS)
model Transaction {
  id            Int       @id @default(autoincrement())
  barbershopId  String    @map("barberia_id") // El dinero entra a la tienda
  barberId      String    @map("personal_id") // Cobrado por este barbero
  appointmentId String?   @map("cita_id")
  
  type          TransactionType @map("tipo")
  amount        Decimal   @db.Decimal(10, 2) @map("monto")
  method        PaymentMethod @map("metodo_pago")

  description   String?   @map("descripcion")
  createdAt     DateTime  @default(now()) @map("fecha_creacion")
  dailyCloseId  Int?      @map("cierre_dia_id")

  barbershop    Barbershop   @relation(fields: [barbershopId], references: [id])
  barber        Barber       @relation(fields: [barberId], references: [id])
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  dailyClose    DailyClose?  @relation(fields: [dailyCloseId], references: [id])

  @@map("movimientos_financieros")
}

/// 🟢 APERTURA DE CAJA
model DailyOpen {
  id            Int       @id @default(autoincrement())
  barbershopId  String    @map("barberia_id")
  barberId      String    @map("personal_id") // Quién abrió
  date          DateTime  @map("fecha") @db.Date
  
  initialCash   Decimal   @db.Decimal(10, 2) @map("efectivo_inicial")
  openedAt      DateTime  @default(now()) @map("hora_apertura")

  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])
  barber        Barber     @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barbershopId, barberId, date])
  @@map("aperturas_caja")
}

/// 🔴 CIERRE DE CAJA
model DailyClose {
  id            Int       @id @default(autoincrement())
  barbershopId  String    @map("barberia_id")
  barberId      String    @map("personal_id") // Quién cerró
  date          DateTime  @map("fecha") @db.Date
  
  totalCash     Decimal   @db.Decimal(10, 2) @map("total_efectivo")
  totalTransfer Decimal   @db.Decimal(10, 2) @map("total_digital")
  totalDay      Decimal   @db.Decimal(10, 2) @map("total_dia")
  closedAt      DateTime  @default(now()) @map("hora_cierre")

  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])
  barber        Barber     @relation(fields: [barberId], references: [id])
  transactions  Transaction[]

  @@unique([barbershopId, barberId, date])
  @@map("cierres_caja")
}

/// ⭐ REPUTACIÓN
model Review {
  id            Int       @id @default(autoincrement())
  appointmentId String    @unique @map("cita_id")

  barberId      String    @map("personal_id") 
  
  rating        Int       @map("puntuacion")
  comment       String?   @map("comentario")
  isVisible     Boolean   @default(true) @map("visible")
  createdAt     DateTime  @default(now()) @map("fecha")

  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  barber        Barber      @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("calificaciones")
}

/// 🖼️ GALERÍA
model GalleryImage {
  id            Int       @id @default(autoincrement())
  barbershopId  String    @map("barberia_id") 
  serviceId     Int?      @map("servicio_id")
  
  imageUrl      String    @map("url_imagen")
  createdAt     DateTime  @default(now()) @map("fecha_subida")

  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  service       Service?   @relation(fields: [serviceId], references: [id])

  @@map("galeria")
}

/// 🔔 NOTIFICACIONES
model Notification {
  id        Int      @id @default(autoincrement())
  barberId  String   @map("personal_id")
  title     String   @map("titulo")
  message   String   @map("mensaje")
  isRead    Boolean  @default(false) @map("leida")
  createdAt DateTime @default(now()) @map("fecha_creacion")

  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}